{
  "tests": [
    {
      "name": "Register duplicate",
      "method": "POST",
      "path": "/?action=register",
      "body": {"name": "Тест Юзер", "email": "test_unique_xyz123@example.com", "password": "secret123"},
      "expectedStatus": 409,
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_unique_xyz123@example.com", "password": "wrongpass"},
      "expectedStatus": 401
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    }
  ]
}